function getServerInfo()
    local info = {
        ["🌐 Server"] = game.JobId or "Unknown",
        ["👥 Players"] = #Players:GetPlayers() .. "/" .. game.Players.MaxPlayers,
        ["📌 Place ID"] = game.PlaceId,
        ["🏷️ Game"] = game.Name,
        ["🎮 Creator"] = game.CreatorId,
        ["⚡ FPS"] = math.floor(1 / RunService.RenderStepped:Wait()),
        ["🕒 Uptime"] = math.floor(workspace.DistributedGameTime / 60) .. " min",
        ["🌍 Region"] = game.GetService("MemStorageService"):GetRegionCode(),
        ["🔐 Private"] = game.PrivateServerId ~= "" and "Yes" or "No",
        ["💾 Memory"] = math.floor(collectgarbage("count")) .. " KB",
        ["📡 Ping"] = math.floor(game:GetService("Stats"):GetValue("Network/ServerStatsItem/DataStats/Ping") * 1000)
    }
    return info
end

-- ========== ESP RGB FUNCTIONS ==========
function createESP(player)
    if player == LocalPlayer then return end
    
    local function addESP(character)
        if not character then return end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "HKL_ESP"
        highlight.Parent = character
        highlight.FillTransparency = espSettings.FillTransparency
        highlight.OutlineTransparency = 0
        highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        
        -- RGB Update
        local rgbConnection
        if espSettings.RGBMode then
            local hue = 0
            rgbConnection = RunService.RenderStepped:Connect(function()
                if not highlight or not highlight.Parent then
                    if rgbConnection then rgbConnection:Disconnect() end
                    return
                end
                hue = (hue + 0.01) % 1
                local rgbColor = Color3.fromHSV(hue, 1, 1)
                highlight.OutlineColor = rgbColor
                highlight.FillColor = rgbColor
            end)
        end
        
        local connection = character:FindFirstChildOfClass("Humanoid").Died:Connect(function()
            highlight:Destroy()
            if rgbConnection then rgbConnection:Disconnect() end
        end)
        
        table.insert(espConnections, connection)
    end
    
    if player.Character then
        addESP(player.Character)
    end
    
    player.CharacterAdded:Connect(addESP)
end

function toggleESP(state)
    espEnabled = state
    
    if state then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                createESP(player)
            end
        end
        Players.PlayerAdded:Connect(function(player)
            if espEnabled then
                createESP(player)
            end
        end)
    else
        for _, conn in ipairs(espConnections) do
            conn:Disconnect()
        end
        espConnections = {}
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                for _, obj in ipairs(player.Character:GetChildren()) do
                    if obj.Name == "HKL_ESP" then
                        obj:Destroy()
                    end
                end
            end
        end
    end
end

-- ========== AIMBOT FUNCTIONS ==========
function getClosestPlayer()
    local closest = nil
    local shortestDistance = aimbotSettings.FOV
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(aimbotSettings.TargetPart) then
            if aimbotSettings.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end
            
            local targetPart = player.Character[aimbotSettings.TargetPart]
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
            
            if onScreen or not aimbotSettings.VisibleCheck then
                local distance = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closest = player
                end
            end
        end
    end
    
    return closest
end

-- Input para aimbot
local aimbotInput
if aimbotSettings.Key == "MouseButton2" then
    aimbotInput = UserInputType.MouseButton2
elseif aimbotSettings.Key == "MouseButton1" then
    aimbotInput = UserInputType.MouseButton1
else
    aimbotInput = Enum.KeyCode[aimbotSettings.Key]
end

UserInputService.InputBegan:Connect(function(input)
    if aimbotSettings.Enabled and input.UserInputType == aimbotInput then
        local target = getClosestPlayer()
        if target and target.Character then
            local targetPart = target.Character:FindFirstChild(aimbotSettings.TargetPart)
            if targetPart then
                local targetPos = targetPart.Position
                if aimbotSettings.Prediction and target.Character:FindFirstChild("Humanoid") then
                    local velocity = target.Character.HumanoidRootPart.Velocity
                    targetPos = targetPos + velocity * 0.1
                end
                TweenService:Create(Camera, TweenInfo.new(aimbotSettings.Smoothness / 10, Enum.EasingStyle.Linear), {
                    CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
                }):Play()
            end
        end
    end
end)

-- AimLock (mantiene la mira)
if aimbotSettings.AimLock then
    RunService.RenderStepped:Connect(function()
        if aimbotSettings.Enabled and aimbotSettings.AimLock then
            local target = getClosestPlayer()
            if target and target.Character then
                local targetPart = target.Character:FindFirstChild(aimbotSettings.TargetPart)
                if targetPart then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
                end
            end
        end
    end)
end

